// check undefined classes:
class UsesUndefined() {
  var a : UndefinedAttrClass = 0;
  def b(p : UndefinedParameterClass) : UndefinedResultClass =
    { var v : UndefinedLetClass = new UndefinedNewClass();
      v match {
        case b : UndefinedBranchClass => ""
      }
    }
  ;
}

class IllegalNothing() {
  var x : Nothing = x;
}


// check type_leq and type_lub:
class Root() { }
class FirstChild(var x : Int) extends Root(x) {
  { "" };
  def useful() : String = 0;
}
class SecondChild() extends Root() {
  { this };
  def useful() : Int = "";
}
class FirstGrandChild() extends FirstChild() {
  { true }; // implicitly inheriting without enough params
}
class LastGrandChild() extends SecondChild() {}

class CheckTypes() {
  var root : Root = null;
  var firstChild : FirstChild = null;
  var secondChild : SecondChild = null;
  var firstGrandChild : FirstGrandChild = null;
  var lastGrandChild : LastGrandChild = null;
  def test_leq() : Any = {
    // every assignment is illegal:
      firstChild = root ;
      firstChild = secondChild ;
      firstChild = lastGrandChild ;
      secondChild = root;
      secondChild = firstChild;
      secondChild = firstGrandChild;
      firstGrandChild = root;
      firstGrandChild = firstChild;
      firstGrandChild = secondChild;
      firstGrandChild = lastGrandChild;
      lastGrandChild = root;
      lastGrandChild = firstChild;
      lastGrandChild = secondChild;
      lastGrandChild = firstGrandChild
  };
  var a : Any = abort();
  var i : Int = false;
  var s : String = true;
  var b : Boolean = 0;
  var u : Unit = a;
  def test_lub() : Any = {
    // every assignment is illegal:
      root = if (true) root else 0;
      root = if (true) 0 else root;
      i = if (true) root else 0;
      i = if (true) 0 else root;
      root = if (true) root else "hi";
      root = if (true) "hi" else root;
      s = if (true) root else "hi";
      s = if (true) "hi" else root;
      s = if (true) "hi" else null;
      s = if (true) null else "hi";
      i = if (true) 0 else null;
      i = if (true) null else 0;
      b = if (true) true else null;
      b = if (true) null else true;
      u = if (true) () else null;
      u = if (true) null else ();
      // no testing of integers and strings after this:
      firstChild = if (true) firstChild else root;
      firstChild = if (true) root else firstChild;
      firstChild = if (true) null else root;
      firstChild = if (true) root else null;
      secondChild = if (true) secondChild else root;
      secondChild = if (true) root else secondChild;
      firstChild = if (true) firstChild else secondChild;
      firstChild = if (true) secondChild else firstChild;
      secondChild = if (true) firstChild else secondChild;
      secondChild = if (true) secondChild else firstChild;
      firstChild = if (true) firstGrandChild else root;
      firstChild = if (true) root else firstGrandChild;
      secondChild = if (true) lastGrandChild else root;
      secondChild = if (true) root else lastGrandChild;
      firstChild = if (true) firstGrandChild else secondChild;
      firstChild = if (true) secondChild else firstGrandChild;
      secondChild = if (true) firstGrandChild else secondChild;
      secondChild = if (true) secondChild else firstGrandChild;
      secondChild = if (true) lastGrandChild else firstChild;
      secondChild = if (true) firstChild else lastGrandChild;
      firstChild = if (true) lastGrandChild else firstChild;
      firstChild = if (true) firstChild else lastGrandChild;
      firstChild = if (true) lastGrandChild else firstGrandChild;
      firstChild = if (true) firstGrandChild else lastGrandChild;
      secondChild = if (true) lastGrandChild else firstGrandChild;
      secondChild = if (true) firstGrandChild else lastGrandChild
  };
}

